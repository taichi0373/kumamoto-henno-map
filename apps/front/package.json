{
  "name": "front",
  "version": "0.1.0",
  "private": true,
  "main": "src/main.ts",
  "scripts": {
    "serve": "vite",
    "build": "vite build",
    "lint": "eslint src --ext .ts,.tsx,.vue",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@primevue/themes": "^4.5.4",
    "axios": "^1.13.4",
    "maplibre-gl": "^5.24.0",
    "pinia": "^3.0.4",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "vue": "^3.5.34",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@storybook/vue3": "^10.3.6",
    "@storybook/vue3-vite": "^10.3.6",
    "@vitejs/plugin-vue": "^6.0.6",
    "vue-eslint-parser": "^10.3.0",
    "@types/jest": "^30.0.0",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.0",
    "eslint-plugin-vue": "^10.9.1",
    "jest": "^30.4.2",
    "pg": "^8.20.0",
    "sass": "^1.99.0",
    "storybook": "^10.3.6",
    "vite": "^8.0.12",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "typescript": "^6.0.3"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.60.3"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true,
      "browser": true,
      "es6": true,
      "jest": true
    },
    "extends": [
      "plugin:vue/essential",
      "eslint:recommended"
    ],
    "parserOptions": {
      "parser": "@typescript-eslint/parser",
      "ecmaVersion": 2020,
      "sourceType": "module"
    },
    "plugins": [
      "@typescript-eslint"
    ],
    "overrides": [
      {
        "files": ["*.ts"],
        "parser": "@typescript-eslint/parser"
      }
    ],
    "rules": {
      "vue/multi-word-component-names": "off",
      "no-unused-vars": "off",
      "@typescript-eslint/no-unused-vars": "warn",
      "@typescript-eslint/no-explicit-any": "off"
    }
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ]
}
